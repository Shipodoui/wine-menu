<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Restaurant Menu</title>
    <link href="style.css" rel="stylesheet" />
  </head>
  <body>
    <header>
      <h1>My Restaurant</h1>
    </header>
    <nav>
      <button data_view="vins" onclick="navigate('vins')">Vins</button>
      <button data_view="entrees" onclick="navigate('entrees')">Entrées</button>
      <button data_view="tapas" onclick="navigate('tapas')">Tapas</button>
      <button data_view="plats" onclick="navigate('plats')">Plats</button>
      <button data_view="desserts" onclick="navigate('desserts')">Desserts</button>
    </nav>
    <main>
      <!-- CATEGORIES -->
      <section class="view category" id="vins">
        <div class="menuItem" onclick="navigate('beaujolais-nouveau')">
          <h3>Beaujolais Nouveau</h3>
          <p>10,00 €</p>
        </div>
        <div class="menuItem" onclick="navigate('vin-blanc-random')">
          <h3>Vin blanc random</h3>
          <p>5,00 €</p>
        </div>
        <div class="menuItem" onclick="navigate('rose-random')">
          <h3>Rosé random</h3>
          <p>2,00 €</p>
        </div>
      </section>
      <section class="view category" id="entrees">
        <div class="menuItem" onclick="navigate('soupe-a-la-tomate')">
          <h3>Soupe à la tomate</h3>
          <p>6,00 €</p>
        </div>
        <div class="menuItem" onclick="navigate('salade-cesar')">
          <h3>Salade César</h3>
          <p>8,00 €</p>
        </div>
      </section>
      <section class="view category" id="tapas">
        <div class="menuItem" onclick="navigate('sticks-de-mozzarella')">
          <h3>Sticks de Mozzarella</h3>
          <p>4,00 €</p>
        </div>
        <div class="menuItem" onclick="navigate('super-sticks-de-mozzarella')">
          <h3>Super Sticks de Mozzarella</h3>
          <p>8,00 €</p>
        </div>
      </section>
      <section class="view category" id="plats">
        <div class="menuItem" onclick="navigate('burger-classique')">
          <h3>Burger Classique</h3>
          <p>15,00 €</p>
        </div>
        <div class="menuItem" onclick="navigate('steak')">
          <h3>Steak</h3>
          <p>24,00 €</p>
        </div>
      </section>
      <section class="view category" id="desserts">
        <div class="menuItem" onclick="navigate('gateau-au-chocolat')">
          <h3>Gâteau au chocolat</h3>
          <p>7,00 €</p>
        </div>
        <div class="menuItem" onclick="navigate('tiramisu')">
          <h3>Tiramisu</h3>
          <p>5,00 €</p>
        </div>
        <div class="menuItem" onclick="navigate('banane-flambee')">
          <h3>Banane flambée</h3>
          <p>8,00 €</p>
        </div>
      </section>
      <!-- ITEMS -->
      <section class="view itemPage" id="beaujolais-nouveau">
        <button onclick="navigate('vins')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Beaujolais Nouveau</h2>
            <p>Vin rouge</p>
          </div>
          <div class="item-price">10,00 €</div>
        </div>
        <p>
          <b>Terroir :</b>
           Beaujolais  
        </p>
        <p>
          <b>Couleur :</b>
           Rouge  
          <button style="height: 1.5em;
                                  width: 1.5em;
                                  background-color:#7F1734;
                                  vertical-align: middle;
                                  display: inline-block;
                                  padding: 0;
                                  border: none;
                                margin-bottom: 0em;"></button>
        </p>
        <p>
          <b>Année :</b>
           1999  
        </p>
        <img src="https://picsum.photos/600/300?10" />
      </section>
      <section class="view itemPage" id="vin-blanc-random">
        <button onclick="navigate('vins')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Vin blanc random</h2>
            <p>Vin blanc</p>
          </div>
          <div class="item-price">5,00 €</div>
        </div>
        <p>
          <b>Terroir :</b>
           Champagne  
        </p>
        <p>
          <b>Couleur :</b>
           Blanc  
          <button style="height: 1.5em;
                                  width: 1.5em;
                                  background-color:#f9e8c0;
                                  vertical-align: middle;
                                  display: inline-block;
                                  padding: 0;
                                  border: none;
                                margin-bottom: 0em;"></button>
        </p>
        <p>
          <b>Année :</b>
           2010  
        </p>
        <img src="https://picsum.photos/600/300?10" />
      </section>
      <section class="view itemPage" id="rose-random">
        <button onclick="navigate('vins')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Rosé random</h2>
            <p>Vin rosé</p>
          </div>
          <div class="item-price">2,00 €</div>
        </div>
        <p>
          <b>Terroir :</b>
           Roseraie  
        </p>
        <p>
          <b>Couleur :</b>
           Rosé  
          <button style="height: 1.5em;
                                  width: 1.5em;
                                  background-color:#ee7272;
                                  vertical-align: middle;
                                  display: inline-block;
                                  padding: 0;
                                  border: none;
                                margin-bottom: 0em;"></button>
        </p>
        <p>
          <b>Année :</b>
           1954  
        </p>
        <img src="https://picsum.photos/600/300?10" />
      </section>
      <section class="view itemPage" id="soupe-a-la-tomate">
        <button onclick="navigate('entrees')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Soupe à la tomate</h2>
            <p>Fresh tomato soup with basil.</p>
          </div>
          <div class="item-price">6,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?1" />
      </section>
      <section class="view itemPage" id="salade-cesar">
        <button onclick="navigate('entrees')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Salade César</h2>
            <p>Romaine, parmesan, croutons.</p>
          </div>
          <div class="item-price">8,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?2" />
      </section>
      <section class="view itemPage" id="sticks-de-mozzarella">
        <button onclick="navigate('tapas')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Sticks de Mozzarella</h2>
            <p>Mozzarella panée fondante dans une chapelure croustillante.</p>
          </div>
          <div class="item-price">4,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?8" />
      </section>
      <section class="view itemPage" id="super-sticks-de-mozzarella">
        <button onclick="navigate('tapas')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Super Sticks de Mozzarella</h2>
            <p>Mozzarella panée fondante dans une chapelure croustillante (deux fois plus de sticks).</p>
          </div>
          <div class="item-price">8,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?8" />
      </section>
      <section class="view itemPage" id="burger-classique">
        <button onclick="navigate('plats')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Burger Classique</h2>
            <p>Beef burger with fries.</p>
          </div>
          <div class="item-price">15,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?3" />
      </section>
      <section class="view itemPage" id="steak">
        <button onclick="navigate('plats')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Steak</h2>
            <p>Grilled steak with sauce.</p>
          </div>
          <div class="item-price">24,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?4" />
      </section>
      <section class="view itemPage" id="gateau-au-chocolat">
        <button onclick="navigate('desserts')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Gâteau au chocolat</h2>
            <p>Rich chocolate cake.</p>
          </div>
          <div class="item-price">7,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?5" />
      </section>
      <section class="view itemPage" id="tiramisu">
        <button onclick="navigate('desserts')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Tiramisu</h2>
            <p>Tiramisu au café.</p>
          </div>
          <div class="item-price">5,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?6" />
      </section>
      <section class="view itemPage" id="banane-flambee">
        <button onclick="navigate('desserts')">← Retour</button>
        <div class="item-info">
          <div class="item-desc">
            <h2>Banane flambée</h2>
            <p>Banane flambée au rhum.</p>
          </div>
          <div class="item-price">8,00 €</div>
        </div>
        <img src="https://picsum.photos/600/300?7" />
      </section>
    </main>
    <script src="script.js"></script>
    <div id="bottom-background"></div>
  </body>
</html>
